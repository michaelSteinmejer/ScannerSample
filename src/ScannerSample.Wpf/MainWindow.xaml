<Window x:Class="ScannerSample.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ScannerSample.Wpf.ViewModels"
        Title="Scanner Sample" Height="720" Width="1080" MinHeight="620" MinWidth="920"
        Background="#F3F4F6">
    <Window.Resources>
        <Style x:Key="PreflightIndicatorStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="#9CA3AF" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding PreflightState}" Value="{x:Static vm:PreflightState.Ready}">
                    <Setter Property="Fill" Value="#16A34A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PreflightState}" Value="{x:Static vm:PreflightState.Blocked}">
                    <Setter Property="Fill" Value="#DC2626" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PreflightState}" Value="{x:Static vm:PreflightState.Warning}">
                    <Setter Property="Fill" Value="#D97706" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Scanner" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,16" />

                    <TextBlock Text="Device" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <ComboBox Height="30"
                              ItemsSource="{Binding Devices}"
                              SelectedItem="{Binding SelectedDevice}"
                              DisplayMemberPath="Name"
                              IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBooleanConverter}}" />

                    <Button Content="Refresh devices"
                            Height="34"
                            Margin="0,10,0,20"
                            Command="{Binding RefreshDevicesCommand}" />

                    <Border Background="#F9FAFB" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Ellipse Width="14" Height="14" Margin="0,3,10,0" VerticalAlignment="Top" Style="{StaticResource PreflightIndicatorStyle}" />

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Feeder preflight" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding FeederStatusText}" TextWrapping="Wrap" Foreground="#374151" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding DoubleFeedStatusText}" TextWrapping="Wrap" Foreground="#6B7280" Margin="0,3,0,8" />
                                <Button Content="Check feeder" Height="30" Command="{Binding CheckFeederCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Text="Profile" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

                    <TextBlock Text="DPI" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <ComboBox Height="30"
                              ItemsSource="{Binding DpiOptions}"
                              SelectedItem="{Binding SelectedDpi}"
                              DisplayMemberPath="Label" />

                    <TextBlock Text="Color mode" FontWeight="SemiBold" Margin="0,14,0,6" />
                    <ComboBox Height="30"
                              ItemsSource="{Binding ColorModeOptions}"
                              SelectedItem="{Binding SelectedColorMode}"
                              DisplayMemberPath="Label" />

                    <CheckBox Content="Duplex" IsChecked="{Binding Duplex}" Margin="0,16,0,0" />
                    <CheckBox Content="Use feeder / ADF" IsChecked="{Binding UseFeeder}" Margin="0,8,0,0" />
                    <CheckBox Content="Auto feed" IsChecked="{Binding AutoFeed}" Margin="0,8,0,0" />
                    <CheckBox Content="Show driver UI" IsChecked="{Binding ShowDriverUi}" Margin="0,8,0,0" />
                    <CheckBox Content="Show driver indicators" IsChecked="{Binding ShowIndicators}" Margin="0,8,0,0" />
                    <CheckBox Content="Discard blank pages" IsChecked="{Binding DiscardBlankPages}" Margin="0,8,0,0" />
                    <CheckBox Content="Auto deskew" IsChecked="{Binding AutoDeskew}" Margin="0,8,0,0" />
                    <CheckBox Content="Auto rotate" IsChecked="{Binding AutoRotate}" Margin="0,8,0,0" />
                    <CheckBox Content="Auto border detection" IsChecked="{Binding AutoBorderDetection}" Margin="0,8,0,0" />
                    <CheckBox Content="Double-feed detection" IsChecked="{Binding DoubleFeedDetection}" Margin="0,8,0,16" />

                    <TextBlock Text="Max pages" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <ComboBox Height="30"
                              Margin="0,0,0,16"
                              ItemsSource="{Binding MaxPagesOptions}"
                              SelectedItem="{Binding SelectedMaxPages}"
                              DisplayMemberPath="Label" />

                    <TextBlock Text="Output" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <ComboBox Height="30"
                              ItemsSource="{Binding OutputFormatOptions}"
                              SelectedItem="{Binding SelectedOutputFormat}"
                              DisplayMemberPath="Label" />

                    <Button Content="Start scan"
                            Height="40"
                            Margin="0,22,0,8"
                            FontWeight="SemiBold"
                            Command="{Binding StartScanCommand}" />
                    <Button Content="Cancel"
                            Height="34"
                            Command="{Binding CancelScanCommand}" />

                    <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Foreground="#374151" Margin="0,18,0,0" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="2" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,14">
                    <TextBlock Text="Scanned pages" FontSize="22" FontWeight="SemiBold" DockPanel.Dock="Left" />
                    <TextBlock Text="{Binding OutputFolder}" Foreground="#4B5563" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                </DockPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding PageFiles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="190" Height="270" Margin="0,0,14,14" Background="#F9FAFB" BorderBrush="#D1D5DB" BorderThickness="1">
                                    <Image Source="{Binding}" Stretch="Uniform" Margin="6" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
