<Window x:Class="ScannerSample.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scanner Sample" Height="720" Width="1080" MinHeight="620" MinWidth="920"
        Background="#F3F4F6">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="18">
            <StackPanel>
                <TextBlock Text="Scanner" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,16" />

                <TextBlock Text="Device" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ComboBox x:Name="DeviceComboBox" Height="30" DisplayMemberPath="Name" />

                <Button x:Name="RefreshButton" Content="Refresh devices" Height="34" Margin="0,10,0,20" Click="RefreshButton_Click" />

                <TextBlock Text="Profile" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

                <TextBlock Text="DPI" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ComboBox x:Name="DpiComboBox" Height="30" SelectedIndex="1">
                    <ComboBoxItem Content="200" />
                    <ComboBoxItem Content="300" />
                    <ComboBoxItem Content="400" />
                    <ComboBoxItem Content="600" />
                </ComboBox>

                <TextBlock Text="Color mode" FontWeight="SemiBold" Margin="0,14,0,6" />
                <ComboBox x:Name="ColorModeComboBox" Height="30" SelectedIndex="1">
                    <ComboBoxItem Content="BlackAndWhite" />
                    <ComboBoxItem Content="Grayscale" />
                    <ComboBoxItem Content="Color" />
                </ComboBox>

                <CheckBox x:Name="DuplexCheckBox" Content="Duplex" IsChecked="True" Margin="0,16,0,0" />
                <CheckBox x:Name="FeederCheckBox" Content="Use feeder / ADF" IsChecked="True" Margin="0,8,0,0" />
                <CheckBox x:Name="DriverUiCheckBox" Content="Show driver UI" IsChecked="True" Margin="0,8,0,16" />

                <TextBlock Text="Output" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ComboBox x:Name="OutputFormatComboBox" Height="30" SelectedIndex="0">
                    <ComboBoxItem Content="PngPages" />
                    <ComboBoxItem Content="MultiPageTiff" />
                </ComboBox>

                <Button x:Name="ScanButton" Content="Start scan" Height="40" Margin="0,22,0,8" FontWeight="SemiBold" Click="ScanButton_Click" />
                <Button x:Name="CancelButton" Content="Cancel" Height="34" IsEnabled="False" Click="CancelButton_Click" />

                <TextBlock x:Name="StatusTextBlock" Text="Ready" TextWrapping="Wrap" Foreground="#374151" Margin="0,18,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,14">
                    <TextBlock Text="Scanned pages" FontSize="22" FontWeight="SemiBold" DockPanel.Dock="Left" />
                    <TextBlock x:Name="OutputFolderTextBlock" Foreground="#4B5563" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                </DockPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="PagesItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="190" Height="270" Margin="0,0,14,14" Background="#F9FAFB" BorderBrush="#D1D5DB" BorderThickness="1">
                                    <Image Source="{Binding}" Stretch="Uniform" Margin="6" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
